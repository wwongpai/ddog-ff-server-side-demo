# Datadog credentials
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_app_key_here

# Environment tag — use "production" to match Datadog's default environment for Remote Config
DD_ENV=production
DD_SERVICE=ff-demo
DD_VERSION=1.0.0

# Datadog site (e.g. datadoghq.com, datadoghq.eu, us5.datadoghq.com)
DD_SITE=datadoghq.com
